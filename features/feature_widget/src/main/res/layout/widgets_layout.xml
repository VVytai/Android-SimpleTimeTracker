<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:id="@+id/containerGridWidgetsEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_alignStart="@id/tvGridWidgetsEmpty"
            android:layout_alignTop="@id/tvGridWidgetsEmpty"
            android:layout_alignEnd="@id/tvGridWidgetsEmpty"
            android:layout_alignBottom="@id/tvGridWidgetsEmpty"
            android:alpha="0.5"
            android:background="@drawable/bg_widget_timer" />

        <TextView
            android:id="@+id/tvGridWidgetsEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="@string/record_types_empty"
            android:textColor="@color/textPrimaryDark"
            android:textStyle="bold" />

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/containerGridWidgets"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!--  Items added programmatically  -->

    </LinearLayout>

    <ImageView
        android:id="@+id/ivGridWidgetPrev"
        android:layout_width="@dimen/widget_grid_controls_image_size"
        android:layout_height="@dimen/widget_grid_controls_image_size"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="2dp"
        android:alpha="0.6"
        android:background="@drawable/bg_widget_timer"
        android:src="@drawable/arrow_left"
        android:visibility="gone"
        tools:ignore="ContentDescription"
        tools:tint="@color/white"
        tools:visibility="visible" />

    <Button
        android:id="@+id/btnGridWidgetPrev"
        android:layout_width="@dimen/widget_grid_controls_button_size"
        android:layout_height="@dimen/widget_grid_controls_button_size"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_widget_button"
        android:visibility="gone"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/ivGridWidgetNext"
        android:layout_width="@dimen/widget_grid_controls_image_size"
        android:layout_height="@dimen/widget_grid_controls_image_size"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="2dp"
        android:alpha="0.6"
        android:background="@drawable/bg_widget_timer"
        android:src="@drawable/arrow_right"
        android:visibility="gone"
        tools:ignore="ContentDescription"
        tools:tint="@color/white"
        tools:visibility="visible" />

    <Button
        android:id="@+id/btnGridWidgetNext"
        android:layout_width="@dimen/widget_grid_controls_button_size"
        android:layout_height="@dimen/widget_grid_controls_button_size"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_widget_button"
        android:visibility="gone"
        tools:visibility="visible" />

</RelativeLayout>
