<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="StatisticsDetailCardView">
        <!-- Used for layout preview -->
        <attr name="itemCount" format="integer" />
        <attr name="itemDescription" format="string" />
    </declare-styleable>

    <declare-styleable name="SeriesView">
        <attr name="seriesBarCountInPreview" format="integer" />
        <attr name="seriesMaxValueInPreview" format="integer" />
        <attr name="seriesDividerHeight" format="dimension" />
        <attr name="seriesBarHeight" format="dimension" />
        <attr name="seriesBarCornerRadius" format="dimension" />
        <attr name="seriesBarColor" format="color" />
        <attr name="seriesLegendTextPadding" format="dimension" />
        <attr name="seriesLegendTextSize" format="dimension" />
        <attr name="seriesLegendTextColor" format="color" />
        <attr name="seriesLegendHighlightColor" format="color" />
        <attr name="seriesValueTextSize" format="dimension" />
        <attr name="seriesValueTextColor" format="color" />
    </declare-styleable>

    <declare-styleable name="SeriesCalendarView">
        <attr name="seriesLegendTextSize" />
        <attr name="seriesLegendTextColor" />
    </declare-styleable>
</resources>