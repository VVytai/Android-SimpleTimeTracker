<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <com.example.util.simpletimetracker.feature_views.CategoryView
        android:id="@+id/viewRecordShortcutItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        app:cardElevation="@dimen/record_type_card_elevation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Space
        android:id="@+id/spaceRecordShortcutItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@id/viewRecordShortcutItem"
        app:layout_constraintStart_toStartOf="@id/viewRecordShortcutItem" />

    <androidx.cardview.widget.CardView
        android:id="@+id/btnRecordShortcutItemHint"
        style="@style/InputFieldCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="false"
        app:cardElevation="@dimen/record_type_card_elevation"
        app:layout_constraintStart_toStartOf="@id/spaceRecordShortcutItem"
        app:layout_constraintTop_toTopOf="@id/spaceRecordShortcutItem">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvRecordShortcutItemHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?appInputFieldBorder"
            android:paddingHorizontal="10dp"
            android:paddingVertical="2dp"
            android:textColor="?appTextHintColor"
            android:textSize="11sp"
            app:autoSizeTextType="none"
            tools:text="@string/change_record_shortcut" />

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>