<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:parentTag="android.widget.FrameLayout">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardButtonIconContainer"
        style="@style/EditScreenControlButton"
        android:layout_width="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <Space
                android:id="@+id/spaceButtonIconStart"
                android:layout_width="8dp"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardButtonIcon"
                style="@style/EditScreenControlButtonCard"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/spaceButtonIcon1"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toEndOf="@id/spaceButtonIconStart"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivButtonIcon"
                    style="@style/EditScreenControlButtonImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    tools:ignore="ContentDescription"
                    tools:srcCompat="@drawable/unknown" />

            </androidx.cardview.widget.CardView>

            <Space
                android:id="@+id/spaceButtonIcon1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:visibility="gone"
                app:layout_constraintEnd_toStartOf="@id/tvButtonIcon"
                app:layout_constraintStart_toEndOf="@id/cardButtonIcon" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvButtonIcon"
                style="@style/EditScreenControlButtonText"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:visibility="visible"
                app:layout_constraintEnd_toStartOf="@id/spaceButtonIcon2"
                app:layout_constraintStart_toEndOf="@id/spaceButtonIcon1"
                tools:text="Button text" />

            <Space
                android:id="@+id/spaceButtonIcon2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:visibility="gone"
                app:layout_constraintEnd_toStartOf="@id/spaceButtonIconEnd"
                app:layout_constraintStart_toEndOf="@id/tvButtonIcon" />

            <Space
                android:id="@+id/spaceButtonIconEnd"
                android:layout_width="8dp"
                android:layout_height="match_parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</merge>