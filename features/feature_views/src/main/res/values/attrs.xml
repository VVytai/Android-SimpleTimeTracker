    <declare-styleable name="IconView">
        <attr name="itemIcon" format="reference" />
        <attr name="itemIconText" format="string" />
        <attr name="itemIconColor" format="color" />
        <attr name="itemIconAlpha" format="float" />
    </declare-styleable>

    <declare-styleable name="GoalCheckmarkView">
        <attr name="itemCheckState" format="enum">
            <enum name="hidden" value="0" />
            <enum name="goalNotReached" value="1" />
            <enum name="goalReached" value="2" />
            <enum name="limitNotReached" value="3" />
            <enum name="limitReached" value="4" />
        </attr>
        <attr name="itemIsFiltered" format="boolean" />
    </declare-styleable>

