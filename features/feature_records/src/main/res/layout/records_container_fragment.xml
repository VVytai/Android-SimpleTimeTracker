<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorRecords"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/pagerRecordsContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/dividerRecordContainerDates"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/dividerRecordContainerDates"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginBottom="2dp"
            android:background="?appDividerColor"
            app:layout_constraintBottom_toTopOf="@id/containerRecordsContainerCurrentDate" />

        <androidx.cardview.widget.CardView
            android:id="@+id/containerRecordsContainerCurrentDate"
            style="@style/InputFieldCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardUseCompatPadding="false"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toTopOf="@id/rvDatesContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvRecordsContainerCurrentDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:textColor="?appTextPrimaryColor"
                    android:textStyle="bold"
                    app:layout_constrainedWidth="true"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="@string/title_today" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.cardview.widget.CardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDatesContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnRecordsContainerOptions"
            app:layout_constraintStart_toStartOf="parent"
            tools:layoutManager="LinearLayoutManager"
            tools:listitem="@layout/item_date_selector"
            tools:orientation="horizontal" />

        <View
            android:layout_width="24dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_alpha_gradient"
            android:rotation="180"
            app:layout_constraintBottom_toBottomOf="@id/rvDatesContainer"
            app:layout_constraintEnd_toEndOf="@id/rvDatesContainer"
            app:layout_constraintTop_toTopOf="@id/rvDatesContainer" />

        <View
            android:layout_width="24dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_alpha_gradient"
            app:layout_constraintBottom_toBottomOf="@id/rvDatesContainer"
            app:layout_constraintStart_toStartOf="@id/rvDatesContainer"
            app:layout_constraintTop_toTopOf="@id/rvDatesContainer" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRecordsContainerAdd"
            style="@style/ContainerRangeOptionsButton"
            android:layout_height="0dp"
            android:layout_marginEnd="8dp"
            app:icon="@drawable/add"
            app:layout_constraintBottom_toBottomOf="@id/rvDatesContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/rvDatesContainer" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRecordsContainerOptions"
            style="@style/ContainerRangeOptionsButton"
            android:layout_height="0dp"
            android:layout_marginEnd="4dp"
            app:icon="@drawable/more"
            app:layout_constraintBottom_toBottomOf="@id/rvDatesContainer"
            app:layout_constraintEnd_toStartOf="@id/btnRecordsContainerAdd"
            app:layout_constraintTop_toTopOf="@id/rvDatesContainer" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>